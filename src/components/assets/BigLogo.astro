---
const { class: className, ...rest } = Astro.props;
---

<svg
  class={className}
  {...rest}
  viewBox="0 0 120 12"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <text
    x="50%"
    y="10"
    text-anchor="middle"
    font-family="system-ui, sans-serif"
    font-weight="900"
    font-size="12"
    fill="currentColor"
    letter-spacing="-0.02em"
  >
    BUZZ AND BEE
  </text>
</svg>
