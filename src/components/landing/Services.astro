---
const services = [
  {
    category: "Design",
    brief:
      "We craft stunning, user-centric interfaces and powerful brand identities that leave a lasting impression and drive customer engagement.",
    items: [
      "Brand Identity & Logo Systems",
      "UI/UX Design for Web & Mobile",
      "Interactive Prototypes",
      "Scalable Design Systems",
    ],
  },
  {
    category: "Development",
    brief:
      "We build lightning-fast, secure, and highly scalable web applications using modern technologies to power your core business operations.",
    items: [
      "Custom Web Applications",
      "E-commerce Platforms",
      "High-Performance Static Sites",
      "API Development & Integrations",
    ],
  },
  {
    category: "Marketing",
    brief:
      "We accelerate your revenue growth with data-driven SEO, targeted advertising campaigns, and compelling content strategies that actually convert.",
    items: [
      "Search Engine Optimization (SEO)",
      "Pay-Per-Click (PPC) Advertising",
      "Conversion Rate Optimization (CRO)",
      "Content Strategy & Copywriting",
    ],
  },
];
---

<section id="services">
  <div class="px-8 py-12 max-w-xl mx-auto">
    <h2 class="text-4xl tracking-tight text-base-900 text-balance font-medium">
      Services
    </h2>

    <div class="flex flex-col gap-0.5 mt-4">
      {
        services.map(({ category, brief, items }) => (
          <div class="bg-white p-8 rounded-3xl">
            <h3
              id={`${category.toLowerCase()}-heading`}
              class="text-xl font-medium text-base-900"
            >
              {category}
            </h3>
            <p class="text-sm text-base-700 mt-3 mb-5 leading-relaxed">
              {brief}
            </p>

            <ul
              role="list"
              class="grid grid-cols-1 lg:grid-cols-2 gap-y-1 gap-x-4 mt-2 list-disc pl-4"
            >
              {items.map((title) => (
                <li class="text-[13px] font-medium text-base-600">{title}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
