---
import FigmaLogo from "@/components/assets/FigmaLogo.astro";
import AstroLogo from "@/components/assets/AstroLogo.astro";
import TailwindLogo from "@/components/assets/TailwindLogo.astro";

const pricingTiers = [
  {
    title: "Design & Branding",
    price: "From $300",
    note: "",
    subnote: "Fixed-price or retainer",
    description:
      "For businesses needing a standout brand identity, a complete UI/UX redesign, or high-converting landing pages.",
    highlight: "Core Deliverables:",
    features: [
      "Custom UI/UX Web Design",
      "Brand Identity & Logo Systems",
      "Interactive User Prototypes",
      "Unlimited Design Revisions",
    ],
  },
  {
    title: "Web Engineering",
    price: "From $500",
    note: "",
    subnote: "Fixed-price or retainer",
    description:
      "For startups and agencies requiring lightning-fast, secure, and highly scalable custom web applications.",
    highlight: "Core Deliverables:",
    features: [
      "Full-stack Web Applications",
      "High-Performance Static Sites",
      "E-commerce Integrations",
      "Technical SEO Optimization",
    ],
  },
  {
    title: "Growth Marketing",
    price: "From $400",
    note: "/mo",
    subnote: "Monthly retainer",
    description:
      "For brands looking to aggressively scale their audience and drive measurable ROI through targeted campaigns.",
    highlight: "Core Deliverables:",
    features: [
      "Search Engine Optimization (SEO)",
      "Targeted PPC Campaigns",
      "Data-Driven Content Strategy",
      "Conversion Rate Optimization",
    ],
  },
];
---

<section class="scroll-mt-4" id="pricing">
  <div class="px-8 md:px-12 py-12 max-w-7xl mx-auto">
    <div
      class="grid grid-cols-1 gap-px md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    >
      <section
        class="col-span-full lg:col-span-1 bg-white flex flex-col justify-between rounded-3xl h-full text-base-900 p-8"
      >
        <div>
          <div class="flex gap-2">
            <FigmaLogo class="h-4 text-base-900" />
            <AstroLogo class="h-4 text-base-900" />
            <TailwindLogo class="h-3 text-base-900" />
          </div>
          <p class="text-2xl tracking-tight font-medium text-base-900 mt-4">
            Transparent, <span class="md:block">value-driven pricing</span>
          </p>
          <p class="text-xs text-base-500 mt-2">
            World-class digital solutions tailored exactly to your project's
            scope and scale.
          </p>
        </div>
        <div>
          <div class="flex items-center gap-2 text-base-900">
            <p class="text-xs font-medium">Available for new projects</p>
            <div class="h-2 w-2 rounded-full bg-green-500"></div>
          </div>
          <div class="border-t border-base-200 flex flex-col pt-2 mt-2">
            <span class="text-xs text-base-600 font-normal">
              Dedicated project management, secure online payments, and the
              freedom of
              <span class="italic text-base-900 font-medium">
                flexible engagements.</span
              >
            </span>
          </div>
        </div>
      </section>

      {
        pricingTiers.map((tier) => (
          <section class="bg-white flex flex-col justify-between rounded-3xl h-full text-base-900 p-8">
            <div>
              <div class="flex flex-col gap-2">
                <h3 class="text-lg text-base-900">{tier.title}</h3>
                <p class="text-xl font-medium text-base-900 mt-2">
                  {tier.price}
                  {tier.note && (
                    <span class="text-sm text-base-500">{tier.note}</span>
                  )}
                  <span class="text-base-900 block text-xs">
                    {tier.subnote}
                  </span>
                </p>
              </div>
              <p class="text-xs text-base-600 mt-4">{tier.description}</p>

              <div class="mt-6">
                <p class="text-xs uppercase text-base-900">{tier.highlight}</p>
                <ul
                  class="flex flex-col mt-2 text-sm text-base-600 gap-y-1 list-disc pl-4"
                  role="list"
                >
                  {tier.features.map((feature) => (
                    <li>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="mt-8">
              <a
                href="mailto:buzzandbee25@gmail.com"
                class="rounded-full px-4 border py-2 text-sm font-semibold transition-all flex items-center justify-between bg-white text-base-900 h-10 border-base-200 focus:ring-2 shadow-base-500/5 focus:ring-blue-950 focus:ring-offset-2 ring-offset-base-200 hover:bg-black hover:text-white duration-300 w-full"
              >
                Email us <span>&rarr;</span>
              </a>
            </div>
          </section>
        ))
      }

      <section
        class="h-full p-8 flex flex-col col-span-full md:col-span-1 xl:col-span-2 justify-between order-last md:order-none bg-white rounded-3xl"
      >
        <p class="text-xl font-medium text-base-900">Good to know</p>
        <div class="mt-4">
          <p class="text-xs text-base-500 font-normal">
            Buzz and Bee Digital provides comprehensive, end-to-end solutions.
            Because our core engineering and design team operates out of
            Bangladesh, we are uniquely positioned to offer highly competitive
            pricing structures without ever compromising on world-class quality
            for our international clients.
          </p>

          <div class="border-t border-base-200 flex flex-col pt-4 mt-6">
            <p class="text-xs font-medium text-base-600">
              🌍 We operate globally and support clients across all time zones.
            </p>
          </div>
        </div>
      </section>

      <section
        class="h-full rounded-3xl justify-between col-span-full lg:col-span-1 xl:col-span-2 bg-base-900 text-white p-8"
      >
        <div class="flex flex-col justify-between h-full">
          <h3 class="text-xl font-medium text-white">
            Have a specific project?
          </h3>
          <p class="text-xs text-base-300 mt-4 text-balance leading-relaxed">
            Prefer to write things down? Send us an email with your project
            details and requirements. Our technical lead will review your brief
            and get back to you with a transparent, no-obligation estimate.
          </p>

          <a
            href="mailto:buzzandbee25@gmail.com"
            class="text-sm text-white hover:text-base-300 transition-colors mt-6 font-semibold"
          >
            buzzandbee25@gmail.com &rarr;
          </a>

          <div class="border-t border-base-700 pt-4 mt-6">
            <p class="text-xs text-base-400">
              Response time: Usually within 24 hours
            </p>
          </div>
        </div>
      </section>
    </div>
  </div>
</section>
