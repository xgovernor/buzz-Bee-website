---
const faqs = [
  {
    question: "Who owns the website and code once the project is finished?",
    answer:
      "You do. Once the project is completed and fully paid for, you retain 100% ownership of your website, branding assets, and all associated code. We simply reserve the right to feature the work in our portfolio.",
  },
  {
    question: "Do I need to provide the website content, or do you handle copywriting?",
    answer:
      "That's completely up to you! While some clients prefer to write their own content, we offer comprehensive Content Marketing and Copywriting services. We can write highly engaging, SEO-optimized copy for your entire site so you don't have to lift a finger.",
  },
  {
    question: "Will my new website be mobile-friendly and optimized for Google (SEO)?",
    answer:
      "Absolutely. Every website we build is designed with a 'mobile-first' approach to ensure it looks stunning on all devices. We also bake technical SEO best practices into the core code to ensure you rank highly on Google from day one.",
  },
  {
    question: "How long does a typical web development or branding project take?",
    answer:
      "For a standard branding or web development project, our typical turnaround time is 2 to 6 weeks. However, highly complex custom applications or e-commerce platforms may take longer. We will provide a strict, transparent timeline during our initial kickoff meeting.",
  },
  {
    question: "How do you measure the success of a social media or marketing campaign?",
    answer:
      "We don't guess; we use hard data. We establish Key Performance Indicators (KPIs) at the start of the campaign—such as conversion rates, lead generation, or website traffic—and provide you with transparent, regular reports detailing exactly how your investment is performing.",
  },
];
const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<section id="faq">
  <div class="px-8 py-12 max-w-xl mx-auto">
    <h2 class="text-4xl tracking-tight text-base-900 text-balance font-medium">
      The answers to the most <span class="block"
        >popular frequent questions</span
      >
    </h2>
    <p class="mt-2 text-sm text-base-600">
      Can't find your answer? Send an
      <a
        class="text-blue-500 hover:text-base-900 duration-200"
        href="mailto:buzzandbee25@gmail.com"
      >
        email
      </a>
      and our team will get back to you promptly.
    </p>

    <div
      class="mt-8 bg-white rounded-3xl text-base-900 divide-y divide-base-100"
    >
      {
        faqs.map((faq, i) => (
          <details class="px-8 py-6 group">
            <summary class="cursor-pointer text-sm font-medium  flex justify-between items-center">
              {faq.question}
              <svg
                class="size-4 ml-2 transform transition-transform group-open:rotate-180"
                fill="currentColor"
                viewBox="0 0 20 20"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 011.06.02L10 10.939l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0l-4.24-4.24a.75.75 0 01.02-1.06z"
                  clip-rule="evenodd"
                />
              </svg>
            </summary>
            <p class="mt-2 text-xs text-base-600">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
