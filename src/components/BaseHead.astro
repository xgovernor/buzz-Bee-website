---
import "../styles/global.css";
import { AstroSeo } from "@astrolib/seo";
---

<AstroSeo
  title="Buzz and Bee Digital | Design, Development & Marketing"
  description="Buzz and Bee Digital is a top-tier digital agency providing expert Design, Development, and Marketing services globally from Bangladesh."
  canonical="https://buzzandbeedigital.com/"
  openGraph={{
    url: "https://buzzandbeedigital.com/",
    title: "Buzz and Bee Digital | Growth-Driven Agency",
    description: "Buzz and Bee Digital is a top-tier digital agency providing expert Design, Development, and Marketing services globally.",
    images: [
      {
        url: "https://buzzandbeedigital.com/og-image.jpg",
        width: 1200,
        height: 630,
        alt: "Buzz and Bee Digital Cover Image",
        type: "image/jpeg",
      },
    ],
    site_name: "Buzz and Bee Digital",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    handle: "@buzzandbeedigital",
    site: "@buzzandbeedigital",
    cardType: "summary_large_image",
  }}
/>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Buzz and Bee Digital",
  "image": "https://buzzandbeedigital.com/logo.png",
  "@id": "",
  "url": "https://buzzandbeedigital.com",
  "telephone": "",
  "email": "buzzandbee25@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "BD"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "opens": "09:00",
    "closes": "18:00"
  },
  "sameAs": []
}
</script>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Basic Meta Tags -->
<title>Buzz and Bee Digital | Design, Development & Marketing</title>
<meta
  name="description"
  content="Buzz and Bee Digital is a top-tier digital agency providing expert Design, Development, and Marketing services globally from Bangladesh."
/>
<meta name="keywords" content="digital agency, web development, ui/ux design, marketing, seo, ppc, bangladesh agency" />
<meta name="author" content="Buzz and Bee Digital" />

<!-- Favicons -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/icon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/manifest.webmanifest" />

<!-- Favicon for IE -->
<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />

<!-- Favicons for different sizes -->
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://buzzandbeedigital.com/" />
<meta property="og:title" content="Buzz and Bee Digital | Design, Development & Marketing" />
<meta
  property="og:description"
  content="Buzz and Bee Digital is a top-tier digital agency providing expert Design, Development, and Marketing services globally."
/>
<meta
  property="og:image"
  content="https://buzzandbeedigital.com/og-image.jpg"
/>

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="https://buzzandbeedigital.com/" />
<meta property="twitter:title" content="Buzz and Bee Digital | Growth-Driven Agency" />
<meta
  property="twitter:description"
  content="Buzz and Bee Digital is a top-tier digital agency providing expert Design, Development, and Marketing services globally."
/>
<meta
  property="twitter:image"
  content="https://buzzandbeedigital.com/og-image.jpg"
/>

<!-- Canonical URL -->
<link rel="canonical" href="https://buzzandbeedigital.com/" />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- Apple Touch Icon (already included in favicons, but keeping for backwards compatibility) -->
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<!-- Theme Color for Mobile Browsers -->
<meta name="theme-color" content="#ffffff" />

<!-- Preload local variable font -->
<link
  rel="preload"
  href="/fonts/Geist/webfonts/Geist[wght].woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>

<!-- Preconnect to Calendly for faster booking resolution -->
<link rel="preconnect" href="https://calendly.com" />

<!-- For IE -->
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
